GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Frigate credentials (auto-generated on first run — check: sudo docker logs frigate | grep "default user")
FRIGATE_USER=admin
FRIGATE_PASSWORD=your_frigate_password_here

# Optional overrides (defaults work for Node B)
MQTT_HOST=localhost
MQTT_PORT=1883
FRIGATE_URL=http://localhost:5000
CAMERA_NAME=front_door
COOLDOWN_SECONDS=30
